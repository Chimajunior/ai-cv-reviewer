generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  resumes   Resume[]
}

model Resume {
  id         String   @id @default(cuid())
  fileUrl    String
  uploadedAt DateTime @default(now())

  userId     String
  user       User     @relation(fields: [userId], references: [id])

  analyses   Analysis[]
}

model Analysis {
  id          String   @id @default(cuid())

  score       Int

  strengths   String[]
  weaknesses  String[]
  suggestions String[]

  createdAt   DateTime @default(now())

  resumeId    String
  resume      Resume   @relation(fields: [resumeId], references: [id])
}